{
  "name": "oneshot",
  "version": "1.0.0",
  "type": "module",
  "description": "Zero-config remote desktop via browser. One command, no setup.",
  "main": "dist/index.js",
  "bin": {
    "oneshot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:client": "vite build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.tsx",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit"
  },
  "keywords": ["remote-desktop", "screen-sharing", "cloudflare-tunnel"],
  "license": "MIT",
  "dependencies": {
    "clipboardy": "^4.0.0",
    "express": "^4.21.0",
    "ink": "^5.1.0",
    "@inkjs/ui": "^2.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "qrcode-terminal": "^0.12.0",
    "screenshot-desktop": "^1.15.0",
    "sharp": "^0.33.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.12",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/jest": "^29.5.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
